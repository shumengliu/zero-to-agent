{
  "name": "zero-to-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Hackathon monorepo: TypeScript-only Next.js apps (nextjs-explorer, productify, rentry).",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun --filter rentry dev",
    "dev:explorer": "bun --filter nextjs-explorer dev",
    "dev:productify": "bun --filter productify dev",
    "dev:rentry": "bun --filter rentry dev",
    "build": "bun --filter '*' build",
    "lint": "bun --filter '*' lint"
  },
  "engines": {
    "bun": ">=1.3"
  }
}
