# Required: Vercel AI Gateway key. The investigation agent runs through
# Gateway so we can route to Anthropic without managing per-provider keys.
# Get one at https://vercel.com/d/ai-gateway
AI_GATEWAY_API_KEY=

# Optional. Raises GitHub REST API rate limits during demos. A read-only PAT
# (public_repo scope) is enough.
GITHUB_TOKEN=

# Note: V0_API_KEY is no longer read from the environment. Judges paste their
# own key into the UI; it flows through the request and is never persisted.
